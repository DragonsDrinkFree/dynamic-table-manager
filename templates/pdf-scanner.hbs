{{!-- PDF Scanner Window --}}
<div class="dtm-scanner-container">

  {{!-- LEFT: PDF viewer --}}
  <div class="dtm-scanner-left">
    <div class="dtm-scanner-toolbar">
      <button type="button" data-action="selectPdf" class="dtm-btn-secondary">
        <i class="fas fa-folder-open"></i> Select PDF
      </button>
      <button type="button" data-action="selectSingle"
              class="dtm-btn-secondary{{#if isSelectSingle}} dtm-active{{/if}}"
              {{#unless hasPdf}}disabled{{/unless}}
              title="Draw a region around a single-column table. Handles tables printed across two page-columns (e.g. d100 split into two halves).">
        <i class="fas fa-list-ol"></i> Single Col
      </button>
      <button type="button" data-action="selectMulti"
              class="dtm-btn-secondary{{#if isSelectMulti}} dtm-active{{/if}}"
              {{#unless hasPdf}}disabled{{/unless}}
              title="Draw a region around a true multi-column data table (range + multiple data columns).">
        <i class="fas fa-table-cells"></i> Multi Col
      </button>
      <button type="button" data-action="importRecipe" class="dtm-btn-secondary"
              {{#unless hasPdf}}disabled{{/unless}}
              title="Load a recipe JSON and re-scan its regions on this PDF">
        <i class="fas fa-file-import"></i> Import Recipe
      </button>
      <button type="button" data-action="exportRecipe" class="dtm-btn-secondary"
              {{#unless hasRegions}}disabled{{/unless}}
              title="Save current regions + options as JSON (no table content)">
        <i class="fas fa-file-export"></i> Export Recipe
      </button>
      {{#if hasPdf}}
      <div class="dtm-page-nav">
        <button type="button" data-action="prevPage" {{#if isFirstPage}}disabled{{/if}}>
          <i class="fas fa-chevron-left"></i>
        </button>
        <input type="number" class="dtm-page-input" value="{{currentPage}}" min="1" max="{{totalPages}}" title="Go to page">
        <span class="dtm-page-total">/ {{totalPages}}</span>
        <button type="button" data-action="nextPage" {{#if isLastPage}}disabled{{/if}}>
          <i class="fas fa-chevron-right"></i>
        </button>
      </div>
      {{/if}}
    </div>

    <input type="file" id="dtm-pdf-file-input" accept=".pdf" style="display:none">
    <input type="file" id="dtm-recipe-file-input" accept="application/json,.json" style="display:none">

    <div class="dtm-canvas-wrapper">
      {{#unless hasPdf}}
      <div class="dtm-pdf-empty">
        <i class="fas fa-file-pdf"></i>
        <p>Click <strong>Select PDF</strong> to open a file.</p>
        <p class="dtm-pdf-empty-hint">Pick <strong>Single Col</strong> or <strong>Multi Col</strong>, then draw regions over table content.</p>
      </div>
      {{/unless}}
      <canvas id="dtm-pdf-canvas"></canvas>
      <canvas id="dtm-select-canvas"></canvas>
    </div>
  </div>

  {{!-- RIGHT: Regions + Preview + Footer --}}
  <div class="dtm-scanner-right">

    <div class="dtm-region-list-header">
      <span>Tables</span>
      <span class="dtm-badge">{{totalRegionCount}}</span>
    </div>

    <div class="dtm-group-toolbar">
      <button type="button" data-action="addPrefixGroup" class="dtm-btn-secondary"
              {{#unless hasPdf}}disabled{{/unless}}
              title="Create a new prefix group (e.g. Elf, Fighter) and its first instance. Regions drawn while this instance is active will share a role template with its sibling instances.">
        <i class="fas fa-plus"></i> Prefix Group
      </button>
      <button type="button" data-action="newGroupInstance" class="dtm-btn-secondary"
              {{#unless hasFamilies}}disabled{{/unless}}
              title="Add another instance that shares the active family's role template (e.g. add Dwarf alongside Elf).">
        <i class="fas fa-layer-group"></i> New Instance
      </button>
    </div>

    <div class="dtm-region-list">
      {{#each instances}}
      <div class="dtm-instance-block">
        <div class="dtm-instance-header{{#if this.isActive}} dtm-instance-active{{/if}}"
             data-action="activateInstance" data-instance-id="{{this.id}}"
             title="Click to make this instance the active draw target">
          <button type="button" class="dtm-instance-chevron"
                  data-action="toggleInstanceExpand" data-instance-id="{{this.id}}"
                  title="Expand / collapse">
            <i class="fas {{#if this.isExpanded}}fa-chevron-down{{else}}fa-chevron-right{{/if}}"></i>
          </button>
          <input type="text" class="dtm-instance-name" value="{{this.name}}"
                 placeholder="Instance name" data-instance-id="{{this.id}}"
                 title="Instance prefix (e.g. Elf, Dwarf)">
          <span class="dtm-badge">{{this.regions.length}}</span>
          <button type="button" class="dtm-instance-delete"
                  data-action="deleteInstance" data-instance-id="{{this.id}}"
                  title="Delete instance and all its regions">
            <i class="fas fa-trash"></i>
          </button>
        </div>
        {{#if this.isExpanded}}
        <div class="dtm-instance-regions">
          {{#each this.regions}}
          <div class="dtm-region-item{{#if this.isActive}} dtm-region-active{{/if}}"
               data-region-id="{{this.id}}">
            <input type="text" class="dtm-region-name" value="{{this.name}}" placeholder="Role name">
            {{#if this.isOverride}}<span class="dtm-badge dtm-override-badge" title="Per-region name override (differs from shared role)">~</span>{{/if}}
            <span class="dtm-badge dtm-mode-badge dtm-mode-{{this.mode}}" title="Extraction mode">{{this.mode}}</span>
            <span class="dtm-badge dtm-page-badge">p.{{this.page}}</span>
            <span class="dtm-badge">{{this.entryCount}} rows</span>
            <button type="button" data-action="previewRegion" title="Preview / hide preview">
              <i class="fas fa-eye"></i>
            </button>
            <button type="button" data-action="deleteRegion" title="Delete region">
              <i class="fas fa-trash"></i>
            </button>
          </div>
          {{/each}}
          {{#unless this.regions.length}}
          <div class="dtm-region-empty dtm-instance-empty">Empty &mdash; activate this instance and draw regions.</div>
          {{/unless}}
        </div>
        {{/if}}
      </div>
      {{/each}}

      <div class="dtm-instance-block dtm-ungrouped-block">
        <div class="dtm-instance-header{{#if isUngroupedActive}} dtm-instance-active{{/if}}"
             data-action="activateUngrouped"
             title="Regions drawn while no group is active land here. Click to make Ungrouped the active target.">
          <span class="dtm-instance-chevron dtm-ungrouped-icon"><i class="fas fa-folder-open"></i></span>
          <span class="dtm-ungrouped-label">Ungrouped</span>
          <span class="dtm-badge">{{ungroupedRegions.length}}</span>
        </div>
        <div class="dtm-instance-regions">
          {{#each ungroupedRegions}}
          <div class="dtm-region-item{{#if this.isActive}} dtm-region-active{{/if}}"
               data-region-id="{{this.id}}">
            <input type="text" class="dtm-region-name" value="{{this.name}}" placeholder="Table name">
            <span class="dtm-badge dtm-mode-badge dtm-mode-{{this.mode}}" title="Extraction mode">{{this.mode}}</span>
            <span class="dtm-badge dtm-page-badge">p.{{this.page}}</span>
            <span class="dtm-badge">{{this.entryCount}} rows</span>
            <button type="button" data-action="previewRegion" title="Preview / hide preview">
              <i class="fas fa-eye"></i>
            </button>
            <button type="button" data-action="deleteRegion" title="Delete region">
              <i class="fas fa-trash"></i>
            </button>
          </div>
          {{/each}}
        </div>
      </div>

      {{#unless totalRegionCount}}
      <div class="dtm-region-empty">
        Draw selection boxes over table regions in the PDF to add them here.
      </div>
      {{/unless}}
    </div>

    {{#if activeRegion}}
    <div class="dtm-preview-panel">
      <div class="dtm-preview-header">
        <span class="dtm-preview-title">{{activeRegion.name}}</span>
        {{#if activeRegion.isMultiColumn}}
        <span class="dtm-badge">{{activeRegion.columns.length}} columns</span>
        {{/if}}
      </div>
      {{#if activeRegion.isMultiColumn}}
        {{#each activeRegion.columns}}
        <div class="dtm-preview-col-block">
          <div class="dtm-preview-col-header">{{this.header}}</div>
          {{#each this.entries}}
          <div class="dtm-preview-row">
            <span class="dtm-preview-range">{{this.low}}</span>
            <span class="dtm-preview-name">{{this.name}}</span>
          </div>
          {{/each}}
        </div>
        {{/each}}
      {{else}}
        {{#each activeRegion.entries}}
        <div class="dtm-preview-row">
          <span class="dtm-preview-range">{{this.low}}</span>
          <span class="dtm-preview-name">{{this.name}}</span>
        </div>
        {{/each}}
        {{#unless activeRegion.entries.length}}
        <div class="dtm-region-empty">No data extracted — try a larger region.</div>
        {{/unless}}
      {{/if}}
    </div>
    {{/if}}

    <div class="dtm-scanner-footer">
      <div class="dtm-scanner-options">
        <label class="dtm-option-row">
          <input type="checkbox" name="usePrefix" {{#if usePrefix}}checked{{/if}}>
          Add prefix to table names:
          <input type="text" name="tablePrefix" value="{{tablePrefix}}" placeholder="e.g. Traveller" class="dtm-prefix-input" {{#unless usePrefix}}disabled{{/unless}}>
        </label>
        <label class="dtm-option-row">
          <input type="checkbox" name="makeCompound" {{#if makeCompound}}checked{{/if}}>
          Create compound table for multi-column regions
        </label>
      </div>
      <div class="dtm-dialog-buttons">
        <button type="button" data-action="createTables" class="dtm-btn-primary"
                {{#unless hasRegions}}disabled{{/unless}}>
          <i class="fas fa-check"></i> Create Tables
        </button>
        <button type="button" data-action="cancel" class="dtm-btn-secondary">
          <i class="fas fa-times"></i> Cancel
        </button>
      </div>
    </div>

  </div>
</div>
